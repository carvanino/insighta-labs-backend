# Server
PORT=3004

# Redis (required for caching and rate limiting)
# Managed options: Upstash (https://upstash.com), Railway Redis addon
REDIS_URL=redis://localhost:6379

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/insighta
DB_SSL=false

# External prediction APIs (Stage 1/2 — no keys required)
GENDERIZE_URL=https://api.genderize.io
AGIFY_URL=https://api.agify.io
NATIONALIZE_URL=https://api.nationalize.io

# ── Stage 3 additions (fill in after setting up GitHub OAuth app) ──────────
# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3005/auth/github/callback

# JWT signing secrets (generate with: openssl rand -hex 64)
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# Token expiry (seconds)
ACCESS_TOKEN_EXPIRY=180
REFRESH_TOKEN_EXPIRY=300

# Web portal origin (for CORS + CSRF)
WEB_PORTAL_URL=http://localhost:5173

# Cookie secret (generate with: openssl rand -hex 32)
COOKIE_SECRET=
